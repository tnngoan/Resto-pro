{
  "name": "@restopro/pos",
  "type": "module",
  "version": "0.1.0",
  "description": "POS Desktop App for RestoPro — offline-first with Electron",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --port 3004",
    "dev:electron": "concurrently \"vite --port 3004\" \"wait-on http://localhost:3004 && electron .\"",
    "build": "tsc && vite build",
    "build:electron": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "zustand": "^4.4.7",
    "axios": "^1.6.2",
    "idb": "^8.0.0",
    "socket.io-client": "^4.7.2",
    "lucide-react": "^0.294.0",
    "uuid": "^9.0.0",
    "iconv-lite": "^0.6.3",
    "escpos": "^3.0.0-alpha.6",
    "escpos-usb": "^3.0.0-alpha.4",
    "@restopro/shared": "workspace:*",
    "@restopro/ui": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.7",
    "tailwindcss": "^3.3.6",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.16",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "concurrently": "^8.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.restopro.pos",
    "productName": "RestoPro POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*.js"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
