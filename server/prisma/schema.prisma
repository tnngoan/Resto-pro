// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  OWNER
  MANAGER
  STAFF
  KITCHEN

  @@map("user_role")
}

enum KitchenStation {
  HOT_KITCHEN
  COLD_KITCHEN
  BAR
  DESSERT
  GRILL

  @@map("kitchen_station")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  NEEDS_ATTENTION
  CLEANING

  @@map("table_status")
}

enum OrderStatus {
  DRAFT
  PLACED
  CONFIRMED
  PREPARING
  READY
  SERVED
  PAID
  COMPLETED
  CANCELLED

  @@map("order_status")
}

enum PaymentMethod {
  CASH
  VNPAY
  MOMO
  ZALOPAY
  CARD
  BANK_TRANSFER

  @@map("payment_method")
}

enum OrderItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED

  @@map("order_item_status")
}

enum StockMovementType {
  IN
  OUT
  WASTE
  ADJUSTMENT

  @@map("stock_movement_type")
}

enum ExpenseCategory {
  FOOD_PURCHASE
  RENT
  UTILITIES
  STAFF_WAGES
  MARKETING
  EQUIPMENT
  OTHER

  @@map("expense_category")
}

// ============================================================================
// MODELS
// ============================================================================

/// Restaurant entity - core container for all restaurant data
model Restaurant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  nameVi    String   @map("name_vi")
  slug      String   @unique
  address   String
  phone     String
  email     String
  logoUrl   String?  @map("logo_url")
  taxCode   String?  @map("tax_code")
  vatRate   Int      @default(8) @map("vat_rate")
  currency  String   @default("VND")
  timezone  String   @default("Asia/Ho_Chi_Minh")
  settings  Json?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  users            User[]
  menuCategories   MenuCategory[]
  menuItems        MenuItem[]
  tables           Table[]
  orders           Order[]
  ingredients      Ingredient[]
  stockMovements   StockMovement[]
  auditLogs        AuditLog[]
  dailyRevenues    DailyRevenue[]
  expenses         Expense[]

  @@map("restaurants")
}

/// User entity - restaurant staff and access control
model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  authUserId   String?  @unique @map("auth_user_id") @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  phone        String?
  role         UserRole @default(STAFF)
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  restaurant       Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders           Order[]     @relation("ServerOrders")
  ordersServed     OrderItem[] @relation("PreparedByUser")
  stockMovements   StockMovement[] @relation("CreatedByUser")
  auditLogs        AuditLog[]  @relation("UserAuditLogs")
  expenses         Expense[]   @relation("CreatedByExpenses")

  @@index([restaurantId])
  @@index([email])
  @@map("users")
}

/// Menu category - organizes menu items
model MenuCategory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  name        String
  nameIt      String   @map("name_it")
  slug        String
  description String?
  imageUrl    String?  @map("image_url")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  restaurant Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems  MenuItem[]

  @@unique([restaurantId, slug])
  @@index([restaurantId])
  @@map("menu_categories")
}

/// Menu item - dishes and beverages
model MenuItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId   String   @map("restaurant_id") @db.Uuid
  categoryId     String   @map("category_id") @db.Uuid
  name           String
  nameIt         String   @map("name_it")
  description    String?
  descriptionIt  String?  @map("description_it")
  price          Int
  imageUrl       String?  @map("image_url")
  station        KitchenStation @default(HOT_KITCHEN)
  prepTimeMinutes Int     @default(15) @map("prep_time_minutes")
  isAvailable    Boolean  @default(true) @map("is_available")
  is86d          Boolean  @default(false)
  sortOrder      Int      @default(0) @map("sort_order")
  allergens      String[] @default([])
  tags           String[] @default([])
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  restaurant     Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category       MenuCategory   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  recipes        Recipe[]
  orderItems     OrderItem[]

  @@index([restaurantId])
  @@index([categoryId])
  @@map("menu_items")
}

/// Table - physical restaurant tables
model Table {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId    String   @map("restaurant_id") @db.Uuid
  name            String
  capacity        Int      @default(4)
  zone            String   @default("Tầng 1")
  status          TableStatus @default(AVAILABLE)
  positionX       Float?   @map("position_x")
  positionY       Float?   @map("position_y")
  qrCode          String?  @map("qr_code")
  currentOrderId  String?  @map("current_order_id") @db.Uuid
  currentCovers   Int      @default(0) @map("current_covers")
  seatedAt        DateTime? @map("seated_at") @db.Timestamptz
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders          Order[]

  @@index([restaurantId])
  @@index([currentOrderId])
  @@map("tables")
}

/// Order - customer orders
model Order {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId    String   @map("restaurant_id") @db.Uuid
  tableId         String?  @map("table_id") @db.Uuid
  orderNumber     Int      @default(autoincrement())
  status          OrderStatus @default(DRAFT)
  subtotal        Int      @default(0)
  vatAmount       Int      @default(0) @map("vat_amount")
  discountAmount  Int      @default(0) @map("discount_amount")
  total           Int      @default(0)
  paymentMethod   PaymentMethod?
  paidAt          DateTime? @map("paid_at") @db.Timestamptz
  notes           String?
  serverId        String?  @map("server_id") @db.Uuid
  customerId      String?  @map("customer_id") @db.Uuid
  covers          Int      @default(1)
  isRush          Boolean  @default(false) @map("is_rush")
  isVip           Boolean  @default(false) @map("is_vip")
  cancelledReason String?  @map("cancelled_reason")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table           Table?     @relation(fields: [tableId], references: [id], onDelete: Set Null)
  server          User?      @relation("ServerOrders", fields: [serverId], references: [id], onDelete: Set Null)
  orderItems      OrderItem[]

  @@unique([restaurantId, orderNumber])
  @@index([restaurantId])
  @@index([tableId])
  @@index([serverId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

/// Order item - individual items in an order
model OrderItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId        String   @map("order_id") @db.Uuid
  menuItemId     String   @map("menu_item_id") @db.Uuid
  name           String
  nameIt         String   @map("name_it")
  quantity       Int      @default(1)
  unitPrice      Int      @map("unit_price")
  totalPrice     Int      @map("total_price")
  status         OrderItemStatus @default(PENDING)
  station        KitchenStation?
  modifications  String[] @default([])
  notes          String?
  preparedBy     String?  @map("prepared_by") @db.Uuid
  preparedAt     DateTime? @map("prepared_at") @db.Timestamptz
  servedAt       DateTime? @map("served_at") @db.Timestamptz
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem       MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  preparedByUser User?     @relation("PreparedByUser", fields: [preparedBy], references: [id], onDelete: Set Null)

  @@index([orderId])
  @@index([menuItemId])
  @@index([status])
  @@index([station])
  @@map("order_items")
}

/// Ingredient - inventory items
model Ingredient {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId  String   @map("restaurant_id") @db.Uuid
  name          String
  unit          String
  currentStock  Float    @default(0) @map("current_stock")
  minStock      Float    @default(0) @map("min_stock")
  costPerUnit   Int      @default(0) @map("cost_per_unit")
  supplierName  String?  @map("supplier_name")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  recipes       Recipe[]
  stockMovements StockMovement[]

  @@index([restaurantId])
  @@map("ingredients")
}

/// Recipe - maps ingredients to menu items with quantities
model Recipe {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menuItemId   String   @map("menu_item_id") @db.Uuid
  ingredientId String   @map("ingredient_id") @db.Uuid
  quantity     Float
  unit         String
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@unique([menuItemId, ingredientId])
  @@index([menuItemId])
  @@index([ingredientId])
  @@map("recipes")
}

/// Stock movement - ingredient transaction log
model StockMovement {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId  String   @map("restaurant_id") @db.Uuid
  ingredientId  String   @map("ingredient_id") @db.Uuid
  type          StockMovementType
  quantity      Float
  unitCost      Int      @default(0) @map("unit_cost")
  totalCost     Int      @default(0) @map("total_cost")
  reason        String?
  referenceId   String?  @map("reference_id") @db.Uuid
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  createdByUser User?      @relation("CreatedByUser", fields: [createdBy], references: [id], onDelete: Set Null)

  @@index([restaurantId])
  @@index([ingredientId])
  @@index([createdAt])
  @@map("stock_movements")
}

/// Audit log - track all data modifications
model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId String   @map("restaurant_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  action       String
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id") @db.Uuid
  oldValues    Json?    @map("old_values")
  newValues    Json?    @map("new_values")
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User?      @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: Set Null)

  @@index([restaurantId])
  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Daily revenue - aggregated daily sales metrics
model DailyRevenue {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId       String   @map("restaurant_id") @db.Uuid
  date               DateTime @db.Date
  totalRevenue       Int      @default(0) @map("total_revenue")
  totalOrders        Int      @default(0) @map("total_orders")
  totalCovers        Int      @default(0) @map("total_covers")
  avgTicket          Int      @default(0) @map("avg_ticket")
  cashRevenue        Int      @default(0) @map("cash_revenue")
  vnpayRevenue       Int      @default(0) @map("vnpay_revenue")
  momoRevenue        Int      @default(0) @map("momo_revenue")
  zalopayRevenue     Int      @default(0) @map("zalopay_revenue")
  cardRevenue        Int      @default(0) @map("card_revenue")
  bankTransferRevenue Int     @default(0) @map("bank_transfer_revenue")
  totalVat           Int      @default(0) @map("total_vat")
  totalDiscounts     Int      @default(0) @map("total_discounts")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  restaurant         Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, date])
  @@index([restaurantId])
  @@index([date])
  @@map("daily_revenues")
}

/// Expense - manual expense entries for P&L tracking
model Expense {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId   String          @map("restaurant_id") @db.Uuid
  description    String
  amount         Int             // VND integer
  category       ExpenseCategory
  date           DateTime        @db.Date
  paymentMethod  PaymentMethod?  @map("payment_method")
  notes          String?
  createdBy      String?         @map("created_by") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdByUser  User?      @relation("CreatedByExpenses", fields: [createdBy], references: [id], onDelete: Set Null)

  @@index([restaurantId])
  @@index([date])
  @@index([category])
  @@map("expenses")
}
