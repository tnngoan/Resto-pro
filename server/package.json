    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.2.10",
    "@types/express": "^4.17.21",
    "@types/bcryptjs": "^2.4.2",
    "@types/passport-jwt": "^3.0.11",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.4",
    "prisma": "^5.6.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3",
    "tsconfig-paths": "^4.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  }
